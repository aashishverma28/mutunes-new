# ============================================================
#  Mutunes – Environment Variables
# ============================================================
#  Copy this file to .env and fill in your values.
#  Never commit .env to Git — it is listed in .gitignore.
# ============================================================

# ── Server ───────────────────────────────────────────────────
# Port the server listens on (Render sets this automatically)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# ── Deployment ───────────────────────────────────────────────
# Nitro server preset.
# Use "node-server" for Render / VPS.
# Use "cloudflare-pages" for Cloudflare Pages.
NITRO_PRESET=node-server

# ── JioSaavn API ─────────────────────────────────────────────
# Base URL for the JioSaavn API proxy (no trailing slash)
VITE_SAAVN_API_URL=https://saavn.sumit.co

# ── Lyrics API ───────────────────────────────────────────────
# Base URL for the LRCLIB lyrics API (no trailing slash)
VITE_LYRICS_API_URL=https://lrclib.net

# ── App Info ─────────────────────────────────────────────────
# Public app name shown in the UI / SEO
VITE_APP_NAME=Mutunes

# Public URL of the deployed app (used for SEO / og:url)
# Example: https://mutunes-new.onrender.com
VITE_APP_URL=http://localhost:3000
